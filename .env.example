# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# GCP project + Vertex AI region
GOOGLE_CLOUD_PROJECT=genai-kb-agent
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex models — must be accessible to the project in the region above.
# In us-central1, gemini-2.5-flash / 2.5-pro / 2.5-flash-lite are available.
GEMINI_MODEL=gemini-2.5-flash
# Auto-used if GEMINI_MODEL 404s (e.g. preview model deprecated).
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-005

# Neon Postgres (SECRET — keep out of git; in Cloud Run use Secret Manager)
PG_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Server
PORT=8080
ALLOWED_ORIGIN=https://alex-huang.dev
